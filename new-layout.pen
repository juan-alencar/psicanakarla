                  "fill": "$primary",
                  "content": "PERGUNTAS FREQUENTES",
                  "fontFamily": "Inter",
                  "fontSize": 11,
                  "fontWeight": "500",
                  "letterSpacing": 3
                },
                {
                  "type": "text",
                  "id": "xibiD",
                  "name": "faqTitle",
                  "fill": "$text-primary",
                  "content": "Dúvidas comuns sobre o atendimento",
                  "fontFamily": "Playfair Display",
                  "fontSize": 34
                }
              ]
            },
            {
              "type": "frame",
              "id": "IhORV",
              "name": "FAQ List",
              "width": 700,
              "layout": "vertical",
              "children": [
                {
                  "id": "mRgC3",
                  "type": "ref",
                  "ref": "Qx0kx",
                  "width": "fill_container",
                  "name": "f1",
                  "descendants": {
                    "YwWuM": {
                      "content": "Como funciona a primeira sessão?"
                    },
                    "QJKpp": {
                      "content": "É um primeiro encontro para que você possa apresentar sua questão, falar sobre o que motivou a busca por atendimento e conhecer a forma como conduzo o trabalho clínico."
                    }
                  }
                },
                {
                  "id": "KQkYd",
                  "type": "ref",
                  "ref": "Qx0kx",
                  "width": "fill_container",
                  "name": "f2",
                  "y": 131,
                  "descendants": {
                    "YwWuM": {
                      "content": "O atendimento online funciona bem?"
                    },
                    "QJKpp": {
                      "content": "Sim. O atendimento online é uma modalidade reconhecida e pode oferecer um trabalho clínico consistente, com escuta, vínculo e continuidade."
                    }
                  }
                },
                {
                  "id": "sFK7p",
                  "type": "ref",
                  "ref": "Qx0kx",
                  "width": "fill_container",
                  "name": "f3",
                  "y": 262,
                  "descendants": {
                    "YwWuM": {
                      "content": "Qual é a frequência das sessões?"
                    },
                    "QJKpp": {
                      "content": "A frequência é combinada de acordo com a necessidade de cada caso, mas geralmente os encontros acontecem semanalmente."
                    }
                  }
                },
                {
                  "id": "LEa0j",
                  "type": "ref",
                  "ref": "Qx0kx",
                  "width": "fill_container",
                  "name": "f4",
                  "y": 393,
                  "descendants": {
                    "YwWuM": {
                      "content": "Posso remarcar ou cancelar uma sessão?"
                    },
                    "QJKpp": {
                      "content": "Sim. Remarcações e cancelamentos podem ser combinados previamente, de acordo com os critérios alinhados no início do atendimento."
                    }
                  }
                },
                {
                  "id": "p6Esi",
                  "type": "ref",
                  "ref": "Qx0kx",
                  "width": "fill_container",
                  "name": "f5",
                  "y": 524,
                  "descendants": {
                    "YwWuM": {
                      "content": "Como recebo informações sobre valores?"
                    },
                    "QJKpp": {
                      "content": "Os valores não são divulgados publicamente. Essas informações são passadas com clareza no contato inicial, em conformidade com os princípios éticos da profissão."
                    }
                  }
                },
                {
                  "id": "IVwZw",
                  "type": "ref",
                  "ref": "Qx0kx",
                  "width": "fill_container",
                  "name": "f6",
                  "y": 655,
                  "descendants": {
                    "YwWuM": {
                      "content": "Como faço para iniciar?"
                    },
                    "QJKpp": {
                      "content": "Basta entrar em contato pelo WhatsApp. A partir disso, conversamos sobre sua demanda, esclarecemos dúvidas e alinhamos os próximos passos."
                    }
                  }
                }
              ]
            }
          ]
