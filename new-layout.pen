            },
            {
              "type": "text",
              "id": "N2Kpz",
              "name": "ctaTitle",
              "fill": "$text-primary",
              "textGrowth": "fixed-width",
              "width": 640,
              "content": "Se algo em você pede escuta,\nesse pode ser o momento de começar.",
              "lineHeight": 1.4,
              "textAlign": "center",
              "fontFamily": "Playfair Display",
              "fontSize": 34
            },
            {
              "type": "text",
